    "test:watch": "bun test --watch src/__tests__/routes"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.4.1",
    "@elysiajs/jwt": "^1.4.1",
    "@elysiajs/swagger": "^1.3.1",
    "@fast-finance/db": "workspace:*",
    "@fast-finance/shared": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "elysia": "^1.4.28",
    "elysia-rate-limit": "^4.5.1",
    "groq-sdk": "^1.1.2",
    "pino": "^10.3.1",
    "postgres": "^3.4.9"
  },
  "devDependencies": {
    "bun-types": "latest",
    "pino-pretty": "^13.1.3",
    "typescript": "^6.0.2"

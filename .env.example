DATABASE_URL=postgresql://postgres:postgres@localhost:5432/fast_finance
TELEGRAM_BOT_TOKEN=your_bot_token_here
GROQ_API_KEY=gsk_your_groq_api_key_here
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# JWT — required in production; generate with: openssl rand -hex 64
JWT_SECRET=change-this-to-a-random-secret-in-production

# Refresh token signing secret — optional (falls back to JWT_SECRET if not set)
# Recommended to set separately in production; generate with: openssl rand -hex 64
REFRESH_TOKEN_SECRET=change-this-in-production

# Optional: set when registering Telegram webhook to secure webhook endpoint
TELEGRAM_WEBHOOK_SECRET=

# Logging level: trace | debug | info | warn | error (default: info)
LOG_LEVEL=info

# ── Telegram Stars billing ────────────────────────────────────────────────────
# No extra credentials needed — billing uses TELEGRAM_BOT_TOKEN above.
# Stars invoices are created via Bot API createInvoiceLink (currency: XTR).
# pre_checkout_query and successful_payment are handled in /bot/webhook.
# Price: 250 Stars ≈ $3.25 / 30 days (configurable in billing.ts: STARS_PRO_PRICE)

# ── Deploy ────────────────────────────────────────────────────────────────────
# GitHub Actions secrets (set in repo Settings → Secrets):
# STAGING_HOST, PROD_HOST, DEPLOY_USER, DEPLOY_SSH_KEY
